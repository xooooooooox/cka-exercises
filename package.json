{
  "name": "cka-exercises-docs",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Static practice web app build tooling for cka-exercises",
  "scripts": {
    "build": "node scripts/build-exercises.mjs && node scripts/build-sw.mjs",
    "build:sw": "node scripts/build-sw.mjs",
    "release": "node scripts/release.mjs",
    "release:dry": "node scripts/release.mjs --dry-run",
    "build:icons": "node scripts/build-icons.mjs",
    "build:kubectl-help": "node scripts/build-kubectl-help.mjs",
    "build:tools": "node scripts/build-kubectl-tools.mjs",
    "build:tools-bundle": "node scripts/build-tools-bundle.mjs",
    "lint": "node scripts/lint-exercises.mjs",
    "verify:quiz-order": "node scripts/verify-quiz-order.mjs",
    "verify:llm-settings": "node scripts/verify-llm-settings.mjs",
    "verify:grader-parse": "node scripts/verify-grader-parse.mjs",
    "link-check": "node scripts/check-links.mjs",
    "preserve": "node scripts/build-exercises.mjs && node scripts/build-sw.mjs && node scripts/build-tools-bundle.mjs --minors=1.35",
    "serve": "python3 -m http.server 8080 --directory docs"
  },
  "devDependencies": {
    "sharp": "^0.33.0"
  }
}
